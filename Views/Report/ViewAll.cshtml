@model List<ST10265272_PROG7312_PortfolioOfEvidence.Models.ReportIssueViewModel>

<h2>All Reported Issues</h2>

<table class="table">
    <thead>
        <tr>
            <th>Location</th>
            <th>Category</th>
            <th>Description</th>
            <th>Media</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var issue in Model)
        {
            <tr>
                <td>@issue.Location</td>
                <td>@issue.Category</td>
                <td>@issue.Description</td>
                <td>
                    @if (!string.IsNullOrEmpty(issue.MediaFileName))
                    {
                        <img src="~/uploads/@issue.MediaFileName" width="100" />
                    }
                    else
                    {
                        <span>No File</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="mt-3">
    <a asp-controller="Report" asp-action="ReportIssue" class="btn btn-primary">
        Back to Report Issue
    </a>
</div>
