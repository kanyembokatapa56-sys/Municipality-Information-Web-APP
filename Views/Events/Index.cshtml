@model SortedDictionary<DateTime, List<ST10265272_PROG7312_PortfolioOfEvidence.Models.EventViewModel>>

@{
    ViewData["Title"] = "Local Events & Announcements";

    var categories = new[]
    {
        "Governance",
        "Infrastructure",
        "Education",
        "Health",
        "Environment"
    };
}

<div class="container mt-4">
    <h2 class="text-center mb-4">@ViewData["Title"]</h2>

    
    <form method="get" class="mb-4">
        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                <input name="keyword" class="form-control" placeholder="Search events..."
                       value="@Context.Request.Query["keyword"]" />
            </div>

            <div class="col-md-3">
                <select name="category" class="form-select">
                    <option value="">All Categories</option>
                    @foreach (var cat in categories)
                    {
                        <option value="@cat" selected="@(Context.Request.Query["category"] == cat ? "selected" : null)">
                            @cat
                        </option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <input type="date" name="date" class="form-control"
                       value="@Context.Request.Query["date"]" />
            </div>

            <div class="col-md-2">
                <button type="submit" class="btn btn-warning w-100">Search</button>
            </div>
        </div>
    </form>

   
    @if (ViewBag.NextUpcoming is ST10265272_PROG7312_PortfolioOfEvidence.Models.EventViewModel next)
    {
        <div class="alert alert-success shadow-sm mb-4">
            <strong>Next Upcoming Event:</strong><br />
            <span class="fw-bold">@next.Title</span><br />
            <small class="text-muted">@next.StartDateTime.ToString("dddd, dd MMM yyyy hh:mm tt")</small>
        </div>
    }

   
    <div class="row">
      
        <div class="col-md-9">
            @if (!Model.Any())
            {
                <div class="alert alert-info text-center">No events found.</div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4 mb-5">
                    @foreach (var group in Model)
                    {
                        foreach (var e in group.Value)
                        {
                            <div class="col">
                                <div class="card h-100 shadow-sm border-0">
                                    <div class="card-header text-center bg-light">
                                        <small class="text-muted">@group.Key.ToString("dddd, dd MMMM yyyy")</small>
                                    </div>
                                    <div class="card-body d-flex flex-column">
                                        <div class="d-flex justify-content-between mb-2">
                                            <span class="badge bg-warning text-dark">@e.Category</span>
                                            <span class="badge bg-light text-muted">@e.Status</span>
                                        </div>
                                        <h5 class="card-title">@e.Title</h5>
                                        <p class="card-text text-muted">@e.Description</p>
                                        <ul class="list-unstyled small mt-auto">
                                            <li><strong>Location:</strong> @e.Location</li>
                                            <li><strong>Time:</strong> @e.StartDateTime.ToString("h:mm tt") - @e.EndDateTime.ToString("h:mm tt")</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            }
        </div>

     
        @if (ViewBag.Recommendations is List<ST10265272_PROG7312_PortfolioOfEvidence.Models.EventViewModel> recs && recs.Any())
        {
            <div class="col-md-3">
                <h5 class="text-primary mb-3">Recommended for You</h5>
                @foreach (var rec in recs)
                {
                    <div class="card mb-3 shadow-sm border-0">
                        <div class="card-body p-3">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="badge bg-warning text-dark">@rec.Category</span>
                                <span class="badge bg-light text-muted">@rec.Status</span>
                            </div>
                            <h6 class="card-title">@rec.Title</h6>
                            <p class="card-text small text-muted">@rec.Description</p>
                            <ul class="list-unstyled small">
                                <li><strong>Location:</strong> @rec.Location</li>
                                <li><strong>Time:</strong> @rec.StartDateTime.ToString("h:mm tt") - @rec.EndDateTime.ToString("h:mm tt")</li>
                            </ul>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>


